{
  "$schema": "../../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Construct",
  "version": "0.1.0",
  "identifier": "com.construct.ai",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../..",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Construct",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximized": false,
        "decorations": true,
        "transparent": false,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://api.github.com https://*.openai.com https://*.anthropic.com https://*.googleapis.com https://api.construct.ai https://github.com https://*.githubusercontent.com; img-src 'self' data: https:; script-src 'self' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Razisafir/construct-ai-agent/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "x7rd+A/oSTUixP8A2n4Pe8llDov5Aaj4/QxwdBtpnuQ="
    }
  },
  "bundle": {
    "targets": ["msi", "nsis", "dmg", "deb", "appimage", "rpm"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon-32x32.png",
      "icons/icon-128x128.png",
      "icons/icon-512x512.png"
    ],
    "externalBin": ["bin/agent-backend"],
    "copyright": "2026 Construct AI Inc. All Rights Reserved.",
    "category": "DeveloperTool",
    "shortDescription": "AI coding agent that never forgets",
    "longDescription": "Autonomous AI coding assistant with persistent memory, multi-agent teams, and 24/7 background execution.",
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0t64", "libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    }
  }
}

{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./out-test",
		"rootDir": "../..",
		"types": ["mocha", "node"],
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": true,
		"allowJs": false,
		"noEmit": false
	},
	"include": [
		"unit/construct/**/*.ts",
		"../../src/vs/platform/construct/common/agent/promptSanitizer.ts"
	]
}

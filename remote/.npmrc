# Native module compilation config for the remote (VS Code Server) layer.
#
# `target`, `runtime`, and `ms_build_id` were removed — they are deprecated in
# npm 11.13.0 and will stop working in npm 12. The Node.js target version is
# now declared in the root package.json `config.remoteNodeVersion` and injected
# via `npm_config_*` environment variables by the postinstall script.
#
# `disturl` is NOT deprecated and is still needed for node header downloads.

disturl="https://nodejs.org/dist"
build_from_source="true"
legacy-peer-deps="true"
timeout=180000

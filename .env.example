# ============================================================================
# Construct AI Agent — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values as needed.
# All paths are relative to the project root unless otherwise noted.
# ============================================================================

# --- SQLite Database ---
# Relational store for raw messages, code events, and structured data.
DB_PATH=./resources/memory/construct.db

# --- ChromaDB Vector Storage ---
# Persistent directory where ChromaDB keeps its SQLite + vector index files.
CHROMA_PATH=./resources/memory/vector

# --- Embedding Model ---
# Sentence-transformers model name.  "all-MiniLM-L6-v2" is the default:
#   - 384-dim embeddings
#   - ~80 MB download
#   - fast inference on CPU
# Alternatives: "all-mpnet-base-v2" (better quality, slower), "multi-qa-MiniLM-L6-cos-v1"
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Python Memory API Server ---
MEMORY_API_HOST=127.0.0.1
MEMORY_API_PORT=8000

# --- Tauri Frontend Dev URL (for CORS) ---
TAURI_DEV_URL=http://localhost:5173

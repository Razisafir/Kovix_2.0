# Native module compilation config for the build toolchain.
#
# `runtime` was removed — deprecated in npm 11.13.0. The postinstall script
# sets npm_config_target to process.versions.node for the build directory,
# which is the correct value (build tools run on system Node, not Electron).
#
# `disturl` is NOT deprecated and is still needed for node header downloads.

disturl="https://nodejs.org/dist"
build_from_source="true"
legacy-peer-deps="true"
timeout=180000

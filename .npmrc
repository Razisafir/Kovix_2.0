# Native module compilation config for Electron.
#
# Historically, `target`, `runtime`, `ms_build_id`, and `arch` were set here
# so that npm's internal node-gyp would compile against the Electron ABI.
# npm 11.13.0 deprecated these keys; npm 12 will stop reading them.
#
# Migration (v1.8.6): those values now live in package.json `config` and are
# injected via `npm_config_*` environment variables by the postinstall /
# rebuild-native-modules scripts. This ensures native modules always build
# against the correct Electron ABI even after npm drops .npmrc passthrough.
#
# `disturl` is NOT deprecated and is still needed so that node-gyp can
# download Electron header files.

disturl="https://electronjs.org/headers"
build_from_source="true"
legacy-peer-deps="true"
timeout=180000

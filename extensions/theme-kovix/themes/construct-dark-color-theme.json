{
  "name": "Construct Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0A0E1A",
    "editor.foreground": "#E0E7FF",
    "editor.lineHighlightBackground": "#1A1F2E",
    "editor.selectionBackground": "#00E5FF22",
    "editorCursor.foreground": "#00E5FF",
    "editorLineNumber.foreground": "#4A5568",
    "editorLineNumber.activeForeground": "#00E5FF",
    "sideBar.background": "#0A0E1A",
    "sideBar.foreground": "#E0E7FF",
    "activityBar.background": "#141B2D",
    "activityBar.foreground": "#E0E7FF",
    "activityBar.activeBorder": "#00E5FF",
    "statusBar.background": "#00E5FF15",
    "statusBar.foreground": "#E0E7FF",
    "statusBarItem.remoteBackground": "#00E5FF",
    "statusBarItem.remoteForeground": "#0A0E1A",
    "titleBar.activeBackground": "#141B2D",
    "titleBar.activeForeground": "#E0E7FF",
    "tab.activeBackground": "#0A0E1A",
    "tab.activeForeground": "#00E5FF",
    "tab.activeBorderTop": "#00E5FF",
    "tab.inactiveBackground": "#141B2D",
    "tab.inactiveForeground": "#4A5568",
    "panel.background": "#0A0E1A",
    "panel.border": "#1A1F2E",
    "terminal.background": "#0A0E1A",
    "terminal.foreground": "#E0E7FF",
    "terminal.ansiGreen": "#00E5FF",
    "terminal.ansiBrightGreen": "#00FFFF",
    "button.background": "#00E5FF",
    "button.foreground": "#0A0E1A",
    "button.hoverBackground": "#00FFFF",
    "input.background": "#141B2D",
    "input.foreground": "#E0E7FF",
    "input.border": "#1A1F2E",
    "inputOption.activeBorder": "#00E5FF",
    "dropdown.background": "#141B2D",
    "list.activeSelectionBackground": "#00E5FF22",
    "list.activeSelectionForeground": "#00E5FF",
    "list.hoverBackground": "#1A1F2E",
    "quickInput.background": "#141B2D",
    "quickInput.foreground": "#E0E7FF"
  },
  "tokenColors": [
    { "name": "Comment", "scope": ["comment"], "settings": { "foreground": "#6A9955", "fontStyle": "italic" } },
    { "name": "Keyword", "scope": ["keyword"], "settings": { "foreground": "#00E5FF", "fontStyle": "bold" } },
    { "name": "String", "scope": ["string"], "settings": { "foreground": "#CE9178" } },
    { "name": "Number", "scope": ["constant.numeric"], "settings": { "foreground": "#B5CEA8" } },
    { "name": "Function", "scope": ["entity.name.function"], "settings": { "foreground": "#DCDCAA" } },
    { "name": "Type", "scope": ["entity.name.type"], "settings": { "foreground": "#4EC9B0" } },
    { "name": "Variable", "scope": ["variable"], "settings": { "foreground": "#9CDCFE" } }
  ]
}

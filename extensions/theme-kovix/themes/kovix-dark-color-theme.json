  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8B949E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF7B72"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#A5D6FF"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#D2A8FF"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#FFA657"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#79C0FF"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#7EE787"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#9DA7B0"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#7EE787"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFA657"
      }
    },
    {
      "name": "Property names (JSON, CSS)",
      "scope": [
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#79C0FF"
      }
    },
    {
      "name": "Property values (CSS)",
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#A5D6FF"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#D2A8FF"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#FFA657"
      }
    },
    {
      "name": "Escape sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FF7B72"
      }
    },
    {
      "name": "Invalid / errors",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F85149"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted.diff",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#3FB950"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted.diff",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#F85149"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#14B8A6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#58A6FF"
      }
    },
    {
      "name": "Markdown code blocks",
      "scope": [
        "markup.raw",
        "fenced_code.block.language"
      ],
      "settings": {
        "foreground": "#A5D6FF"
      }
    }
  ],
  "semanticHighlighting": true,
  "_comment": "Kovix Dark theme \u2014 teal #14B8A6 accent on blue-black #0B1115 (v2 teal identity release)"
}

	"tokenColors": [
		{ "name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5A5E68", "fontStyle": "italic" } },
		{ "name": "Variables and parameters", "scope": ["variable", "string variable", "variable.parameter"], "settings": { "foreground": "#E8EAED" } },
		{ "name": "Keywords / control flow", "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#FF8A5C", "fontStyle": "" } },
		{ "name": "Keyword operators", "scope": ["keyword.operator"], "settings": { "foreground": "#FF8A5C" } },
		{ "name": "Function / class / method names", "scope": ["entity.name.function", "entity.name.class", "entity.name.method", "entity.name.type", "support.function"], "settings": { "foreground": "#8A63FF" } },
		{ "name": "Types / interfaces", "scope": ["entity.name.type.interface", "entity.name.type.class", "entity.name.type.enum", "entity.name.type.struct", "support.type", "support.class"], "settings": { "foreground": "#7CC4FD" } },
		{ "name": "Strings", "scope": ["string", "string.quoted"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "Numbers / constants", "scope": ["constant.numeric", "constant.language", "constant.character", "constant", "punctuation.definition.constant"], "settings": { "foreground": "#FFD466" } },
		{ "name": "Punctuation", "scope": ["punctuation", "meta.brace"], "settings": { "foreground": "#9A9DA6" } },
		{ "name": "HTML/XML tags", "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#FF8A5C" } },
		{ "name": "HTML attribute names", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#FFD466" } },
		{ "name": "CSS property names", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#7CC4FD" } },
		{ "name": "CSS property values", "scope": ["meta.property-value.css", "support.constant.property-value.css"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "CSS selectors", "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#FF8A5C" } },
		{ "name": "JSON keys", "scope": ["string.quoted.double.json", "support.type.property-name.json"], "settings": { "foreground": "#8A63FF" } },
		{ "name": "JSON values", "scope": ["string.quoted.double.json punctuation.definition.string.json"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "Markdown headings", "scope": ["markup.heading.markdown", "entity.name.section.markdown"], "settings": { "foreground": "#FF8A5C", "fontStyle": "bold" } },
		{ "name": "Markdown bold", "scope": ["markup.bold.markdown"], "settings": { "foreground": "#8A63FF", "fontStyle": "bold" } },
		{ "name": "Markdown italic", "scope": ["markup.italic.markdown"], "settings": { "foreground": "#FFD466", "fontStyle": "italic" } },
		{ "name": "Markdown code", "scope": ["markup.inline.raw.string.markdown", "markup.fenced_code.block.markdown"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "Markdown links", "scope": ["markup.underline.link.markdown"], "settings": { "foreground": "#7CC4FD" } },
		{ "name": "JSX tags", "scope": ["entity.name.tag.js", "entity.name.tag.tsx", "entity.name.tag.jsx"], "settings": { "foreground": "#FF8A5C" } },
		{ "name": "JSX attributes", "scope": ["entity.other.attribute-name.js", "entity.other.attribute-name.tsx"], "settings": { "foreground": "#FFD466" } },
		{ "name": "Decorators", "scope": ["meta.decorator", "punctuation.decorator"], "settings": { "foreground": "#FFD466" } },
		{ "name": "Labels", "scope": ["entity.name.label"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "Regex", "scope": ["string.regexp"], "settings": { "foreground": "#FF8A5C" } },
		{ "name": "Escape sequences", "scope": ["constant.character.escape"], "settings": { "foreground": "#FFD466" } },
		{ "name": "Annotations", "scope": ["storage.type.annotation"], "settings": { "foreground": "#FFD466" } },
		{ "name": "Invalid / deprecated", "scope": ["invalid", "invalid.deprecated"], "settings": { "foreground": "#FF8A96" } },
		{ "name": "Diff added", "scope": ["markup.inserted.diff", "meta.diff.header.to.file"], "settings": { "foreground": "#5FE8C6" } },
		{ "name": "Diff deleted", "scope": ["markup.deleted.diff", "meta.diff.header.from.file"], "settings": { "foreground": "#FF8A96" } },
		{ "name": "Git ignore", "scope": ["keyword.control.import-ignore"], "settings": { "foreground": "#5A5E68" } }
	]
}
